{
  "dependencies": {
    "@tobilu/qmd": "^2.5.3",
    "execa": "^9.6.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@changesets/changelog-github": "^0.5.2",
    "@changesets/cli": "^2.31.0",
    "@types/bun": "^1.3.14",
    "@types/node": "^26.1.0",
    "ultracite": "7.8.4"
  },
  "name": "capn-hook",
  "scripts": {
    "build": "bun build src/run.ts --target=node --packages=external --outfile=dist/capn.js",
    "changeset": "changeset",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "prepack": "bun run build",
    "test": "bun test"
  },
  "type": "module",
  "version": "0.2.1",
  "description": "Dynamic memory for coding agents: chart discoveries as you explore, cache-bust when files change",
  "license": "MIT",
  "author": "Cyrus (CyrusNuevoDia)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CyrusNuevoDia/capn-hook.git"
  },
  "homepage": "https://github.com/CyrusNuevoDia/capn-hook#readme",
  "bugs": {
    "url": "https://github.com/CyrusNuevoDia/capn-hook/issues"
  },
  "keywords": [
    "memory",
    "coding-agents",
    "claude-code",
    "codex",
    "agent-memory",
    "cli"
  ],
  "packageManager": "bun@1.3.14",
  "files": [
    "bin",
    "dist",
    "src",
    "README.md",
    "INSTALL.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "capn": "bin/capn"
  },
  "trustedDependencies": [
    "node-llama-cpp",
    "tree-sitter-go",
    "tree-sitter-javascript",
    "tree-sitter-python",
    "tree-sitter-rust"
  ]
}
