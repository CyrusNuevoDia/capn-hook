#!/usr/bin/env sh
set -eu

self=$0
while [ -L "$self" ]; do
  self_dir=$(CDPATH= cd -- "$(dirname -- "$self")" && pwd)
  link=$(readlink "$self")
  case "$link" in
    /*) self=$link ;;
    *) self=$self_dir/$link ;;
  esac
done

bin_dir=$(CDPATH= cd -- "$(dirname -- "$self")" && pwd)
entry="$bin_dir/../dist/capn.js"

if [ ! -f "$entry" ]; then
  echo "capn: dist/capn.js not found — run 'bun run build' in the capn-hook repo" >&2
  exit 1
fi

if command -v bun >/dev/null 2>&1; then
  exec bun "$entry" "$@"
fi
exec node "$entry" "$@"
